# Environment Configuration
NODE_ENV=dev

# Database Configuration (Secrets)
DB_URL="postgresql://postgres:postgres@localhost:5432/cqrs_demo?schema=public"

# Authentication Configuration (Secrets)
JWT_SECRET="supersecret-change-me-in-production"

# Kafka Configuration (Connection Secrets)
# Detailed topic configuration is managed in config/{env}.json
KAFKA_BROKERS="localhost:19092,localhost:29092"
KAFKA_USERNAME=""
KAFKA_PASSWORD=""

# Service Ports (Runtime Overrides)
USER_SERVICE_PORT=3101
PRODUCT_SERVICE_PORT=3102

# Runtime Overrides (Optional)
# LOG_LEVEL="info"
# METRICS_ENABLED="false"

# MCP API Keys (for Trae IDE integration)
GITHUB_PERSONAL_ACCESS_TOKEN=
BRAVE_API_KEY=
