{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "sourceMap": true,
    "strict": false,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@common/*": ["packages/common/src/*"],
      "@cqrs/common/*": ["packages/common/src/*"],
      "@cqrs/drizzle/*": ["packages/drizzle/src/*"]
    },
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false
  },
  "include": ["packages/*/src/**/*", "apps/*/src/**/*", "apps/*/index.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "packages/*/dist",
    "apps/*/dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "references": [{ "path": "./packages/common" }, { "path": "./packages/drizzle" }],
  "files": [],
  "watchOptions": {
    "excludeDirectories": ["**/node_modules", "**/dist"]
  }
}
